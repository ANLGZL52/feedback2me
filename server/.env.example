# PostgreSQL (Railway: Postgres eklendiğinde otomatik gelir)
DATABASE_URL="postgresql://user:pass@host:5432/dbname?sslmode=require"

# JWT imzalama (uzun rastgele string)
JWT_SECRET="change-me-in-production-min-32-chars"

# Sadece geliştirme: POST /auth/dev/login — header: X-Dev-Secret
ALLOW_DEV_AUTH="false"
DEV_AUTH_SECRET="rastgele-gizli-dize"

# İsteğe bağlı
# PORT=8080
# HOST=0.0.0.0
